{
    "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.34/schema.bar.json",
    "monitor": 0,
    "font_family": "JetBrains Mono",
    "transparency_alpha": 128,
    "theme": {
        "palette": "Catppuccin",
        "name": "Mocha",
        "accent": "Rosewater"
    },
    "grouping": {
        "kind": "Widget",
        "style": "DefaultWithShadowB0O1S3",
        "transparency_alpha": 150,
        "rounding": 5
    },
    "center_widgets": [
        {
            "Date": {
                "enable": true,
                "format": "YearMonthDate"
            }
        },
        {
            "Time": {
                "enable": true,
                "format": {
                    "Custom": "%T %Z"
                },
                "timezone": "UTC",
            }
        },
        {
            "Time": {
                "enable": true,
                "format": {
                    "Custom": "%T %Z"
                },
                "timezone": "America/Detroit",
                "label_prefix": "Icon"
            }
        }
    ],
    "left_widgets": [
        {
            "Komorebi": {
                "workspaces": {
                    "enable": true,
                    "hide_empty_workspaces": false
                },
                "layout": {
                    "enable": true
                },
                "focused_window": {
                    "enable": true,
                    "show_icon": true
                }
            }
        }
    ],
    "right_widgets": [
        {
            "Update": {
                "enable": true
            }
        },
        {
            "Media": {
                "enable": true
            }
        },
        {
            "Storage": {
                "enable": true
            }
        },
        {
            "Memory": {
                "enable": true
            }
        },
        {
            "Network": {
                "enable": true,
                "show_total_data_transmitted": false,
                "show_network_activity": false,
                "label_prefix": "Icon"
            }
        },
        {
            "Battery": {
                "enable": true
            }
        }
    ]
}
